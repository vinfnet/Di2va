# ────────────────────────────────────────────────────────────────
# Di2va — Environment Variables
# ────────────────────────────────────────────────────────────────
#
# ⚠️  DO NOT commit real values to git!
#     This file is a TEMPLATE only. Actual secrets go in .env.local
#     (which is listed in .gitignore and will never be committed).
#
# You can also skip this file entirely — on first startup the app
# will show a setup wizard at http://localhost:3000/setup that
# writes .env.local for you automatically.
# ────────────────────────────────────────────────────────────────

# Strava API credentials — https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# App settings
PORT=3000
SESSION_SECRET=

# OAuth callback (must match Strava API "Authorization Callback Domain")
CALLBACK_URL=http://localhost:3000/auth/strava/callback
